.DS_Store
**/.DS_Store

# Local editor/workspace state.
**/docs/.obsidian/
*.swp
*.swo

# Local-only validation helpers for this workstation.
setup_env_local.sh
scripts/validate_all.py
scripts/__pycache__/

# Generated meshes, field maps, Garfield signal tables, and solver output.
**/output/

# Local CMake build trees.
**/garfield/build/
**/garfield/build-*/

# Generated runtime figures. Documentation figures are kept.
**/figures/
!**/docs/figures/
!**/docs/figures/**

# LaTeX byproducts, if notes are exported locally.
**/*.aux
**/*.log
**/*.out
**/*.toc
